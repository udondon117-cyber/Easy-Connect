{
  "expo": {
    "name": "CaptionBridge (キャプションブリッジ)",
    "slug": "caption-bridge",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon-v4.png",
    "scheme": "caption-bridge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon-v4.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A12"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "音声を認識して字幕を表示するためにマイクを使用します。",
        "NSSpeechRecognitionUsageDescription": "音声を認識して字幕を表示するために音声認識機能を使用します。"
      }
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
